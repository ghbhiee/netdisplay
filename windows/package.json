{
  "name": "netdisplay-windows",
  "version": "0.3.0",
  "description": "NetDisplay Windows client: send this PC's screen/window to another machine, or receive as an extra display",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "mock": "node tools/mock-sender.js",
    "cli": "node tools/cli-client.js",
    "probe": "electron tools/probe-codecs.js",
    "probe:encoder": "electron tools/probe-encoder.js",
    "dist": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.netdisplay.windows",
    "productName": "NetDisplay",
    "directories": { "output": "dist" },
    "files": ["main.js", "src/**", "assets/**", "package.json"],
    "win": {
      "target": ["portable"],
      "artifactName": "NetDisplay-${version}-portable.exe"
    }
  }
}

